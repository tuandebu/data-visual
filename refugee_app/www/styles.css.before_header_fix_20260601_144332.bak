@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap');

:root {
  --ink: #111827;
  --muted: #64748b;
  --paper: #f7f1e8;
  --card: #fffdf8;
  --blue: #2f66c5;
  --green: #6f9166;
  --orange: #df7a26;
  --purple: #8064b8;
  --line: rgba(17,24,39,.18);
  --shadow: 0 18px 45px rgba(15,23,42,.13);
}

html { scroll-behavior: smooth; }
body {
  margin: 0;
  background: radial-gradient(circle at top left, #fffaf0 0, var(--paper) 38%, #eee6d9 100%);
  color: var(--ink);
  font-family: Inter, Segoe UI, Arial, sans-serif;
  overflow-x: hidden;
}
.container-fluid { padding: 0; }
.app-shell { min-height: 100vh; }
.command-bar {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(247,241,232,.94);
  border-bottom: 1px solid var(--line);
  backdrop-filter: blur(16px);
  padding: 14px 28px 12px;
}
.brand-row { display: grid; grid-template-columns: 92px 1fr 170px; align-items: center; gap: 22px; }
.brand-icon { width: 76px; height: 76px; display:flex; align-items:center; justify-content:center; border: 2px solid var(--ink); border-radius: 20px; background: white; box-shadow: 8px 8px 0 rgba(17,24,39,.12); }
.globe-icon { width: 58px; height: 58px; }
.brand-copy h1 { margin: 0; text-transform: uppercase; letter-spacing: .04em; font-weight: 900; font-size: clamp(36px, 4.8vw, 72px); line-height: .9; }
.brand-copy p { margin: 10px 0 0; color: var(--muted); font-size: 17px; }
.year-badge { justify-self:end; border: 2px solid var(--ink); padding: 20px 28px; text-transform: uppercase; text-align:center; background:white; box-shadow: 8px 8px 0 rgba(17,24,39,.12); }
.year-badge div { font-size: 12px; letter-spacing:.08em; }
.year-badge strong { font-size: 30px; }
.filter-row { display:grid; grid-template-columns: 1.15fr 1fr 1.2fr 1.2fr 1.2fr .72fr .56fr; gap:12px; margin-top:14px; }
.control { background: rgba(255,255,255,.88); border: 1px solid rgba(17,24,39,.22); border-radius: 18px; padding: 12px 14px; min-height: 82px; box-shadow: 0 5px 0 rgba(17,24,39,.08); }
.control label { text-transform: uppercase; letter-spacing:.09em; font-size: 12px; font-weight: 900; color: var(--ink); }
.reset-btn { width:100%; height: 58px; border-radius: 18px; border: 0; background: var(--ink); color: white; font-weight: 900; font-size: 18px; }
.slide-dots { position: fixed; right: 18px; top: 50%; transform: translateY(-50%); z-index: 60; display:flex; flex-direction:column; gap:10px; }
.slide-dots a { width: 40px; height: 40px; display:flex; align-items:center; justify-content:center; border-radius: 50%; background: rgba(255,255,255,.9); color: var(--ink); text-decoration:none; font-size: 12px; font-weight: 900; border: 1px solid rgba(17,24,39,.20); box-shadow: 0 6px 18px rgba(17,24,39,.12); }
.story-slide { min-height: calc(100vh - 122px); scroll-snap-align: start; padding: 42px 58px 54px; }
.snap-container { scroll-snap-type: y proximity; }
.slide-inner { max-width: 1820px; margin: 0 auto; }
.slide-title { display:grid; grid-template-columns: 78px 1fr; gap:26px; align-items:start; margin-bottom: 28px; }
.slide-number { width:70px; height:70px; display:flex; align-items:center; justify-content:center; border:2px solid var(--ink); border-radius:22px; background:#fff; font-weight:900; font-size:20px; box-shadow: 7px 7px 0 rgba(17,24,39,.10); }
.slide-kicker { color: var(--blue); text-transform: uppercase; letter-spacing:.16em; font-weight: 900; font-size: 14px; margin-bottom: 8px; }
.slide-title h2 { margin:0; font-size: clamp(34px, 4vw, 64px); line-height: .95; letter-spacing:-.04em; }
.slide-title p { margin: 14px 0 0; color: var(--muted); font-size: 18px; max-width: 1020px; }
.metric-grid { display:grid; grid-template-columns: repeat(5, 1fr); gap:18px; margin-bottom:24px; }
.metric-card, .chart-card, .insight-card, .method-card, .timeline-panel, .ranking-note { background: rgba(255,253,248,.94); border: 2px solid rgba(17,24,39,.72); border-radius: 28px; box-shadow: 9px 9px 0 rgba(17,24,39,.12); overflow:hidden; }
.metric-card { min-height:150px; padding:24px; position:relative; }
.metric-icon { display:inline-flex; min-width:48px; height:38px; align-items:center; justify-content:center; border:1px solid rgba(17,24,39,.18); border-radius:20px; background:#f8fafc; font-weight:900; }
.metric-value { font-size: 48px; font-weight: 900; line-height:1; margin-top:20px; }
.metric-label { margin-top:12px; color:#475569; font-weight:700; }
.exec-grid { display:grid; grid-template-columns: 1.2fr 1.05fr .72fr; gap:22px; }
.chart-head { display:grid; grid-template-columns:56px 1fr; gap:16px; padding:20px 22px 14px; border-bottom: 1px solid var(--line); }
.chart-num { display:flex; align-items:center; justify-content:center; width:46px; height:46px; border:1.8px solid var(--ink); border-radius:16px; font-weight:900; background:#fff; }
.chart-title { font-size:20px; font-weight:900; }
.chart-subtitle { margin-top:6px; color:var(--muted); }
.chart-body { padding: 10px 18px 18px; min-height: 360px; }
.insight-card { padding:28px; min-height: 520px; }
.insight-kicker { color:var(--blue); text-transform:uppercase; letter-spacing:.14em; font-weight:900; margin-bottom:18px; }
.insight-card h3 { font-size:30px; line-height:1.1; margin:0 0 16px; }
.insight-card p { color:var(--muted); font-size:17px; line-height:1.55; }
.three-panel-grid { display:grid; grid-template-columns: 1.05fr 1fr .86fr; gap:24px; }
.flow-layout { display:grid; grid-template-columns: 1.35fr .9fr; gap:24px; }
.flow-side { display:grid; gap:24px; }
.ranking-grid { display:grid; grid-template-columns: 1fr 1fr; gap:24px; }
.ranking-note { grid-column: 1 / -1; padding:22px 28px; color:#475569; }
.ranking-note h3 { margin:0 0 6px; color:var(--ink); }
.crisis-layout { display:grid; grid-template-columns: .72fr 1.05fr 1fr 1fr; gap:22px; }
.timeline-panel { padding:26px; }
.timeline-row { display:grid; grid-template-columns: 64px 1fr; gap: 12px; border-top:1px solid rgba(17,24,39,.12); padding:14px 0; }
.timeline-year { font-weight:900; }
.appendix-grid { display:grid; grid-template-columns: repeat(2, 1fr); gap:22px; }
.method-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:24px; }
.method-card { padding:30px; min-height:360px; }
.quality-row { display:flex; justify-content:space-between; padding:13px 0; border-bottom:1px solid rgba(17,24,39,.12); }
@media (max-width: 1200px) { .filter-row, .metric-grid, .exec-grid, .three-panel-grid, .flow-layout, .ranking-grid, .crisis-layout, .appendix-grid, .method-grid { grid-template-columns: 1fr; } .year-badge { display:none; } .slide-dots { display:none; } }

.slide-dots a.active { background: var(--ink); color: #fff; transform: scale(1.08); }
