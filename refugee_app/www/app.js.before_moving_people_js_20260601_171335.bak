// Lightweight polish for slide-scroll dashboard.
(function () {
  function setActiveDot() {
    const sections = [...document.querySelectorAll('.story-slide')];
    const dots = [...document.querySelectorAll('.slide-dots a')];
    if (!sections.length || !dots.length) return;
    let active = 0;
    let best = Infinity;
    sections.forEach((s, i) => {
      const dist = Math.abs(s.getBoundingClientRect().top - 160);
      if (dist < best) { best = dist; active = i; }
    });
    dots.forEach((d, i) => d.classList.toggle('active', i === active));
  }
  window.addEventListener('scroll', setActiveDot, { passive: true });
  window.addEventListener('load', setActiveDot);
})();
